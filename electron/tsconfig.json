{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../dist-electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts", "../src/domain/**/*.ts", "../src/import/**/*.ts", "../src/instruments/**/*.ts", "../src/persistence/**/*.ts"],
  "exclude": ["../src/**/*.test.ts"]
}
